generator client {
  provider = "prisma-client-js"
  
}

datasource db {
  provider = "postgresql"
}

enum PaymentStatus {
  pending
  paid
  failed
  refunded
}

model Member {
  id                 String   @id  @default(cuid())
  lastName           String
  firstName          String
  address            String
  birthDate          String
  memberType         String

  email              String?  @unique
  phone              String   @unique

  motivations        String[] 

  paymentAccepted    Boolean
  agreementAccepted  Boolean

  paymentStatus      PaymentStatus @default(pending)

  stripeCustomerId   String?
  stripePaymentId    String?

  createdAt          DateTime   @default(now())
}